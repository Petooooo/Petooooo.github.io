# Absolute public URL used by Astro for canonical, RSS, Open Graph, and sitemap output.
SITE_URL=https://your-name.iptime.org

# Hostname Caddy serves. Use your ipTIME DDNS hostname or real domain, without protocol.
SITE_DOMAIN=your-name.iptime.org

# Email used by Caddy/Let's Encrypt for certificate account notices.
CADDY_EMAIL=your-email@example.com

# Public profile/repository placeholders used by docs and CMS configuration.
PUBLIC_GITHUB_URL=https://github.com/your-github/portfolio-platform
PUBLIC_RESUME_URL=/about

# Decap CMS placeholders. OAuth is intentionally not configured yet.
DECAP_BACKEND_REPO=your-github/portfolio-platform
DECAP_BACKEND_BRANCH=main
