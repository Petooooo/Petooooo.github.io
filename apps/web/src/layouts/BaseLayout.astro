---
import "../styles/global.css";
import { siteConfig } from "@/site.config";
import { withBase } from "@/lib/urls";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
}

const { title, description = siteConfig.description, image = siteConfig.ogImage, type = "website" } = Astro.props;
const pageTitle = title ? `${title} | ${siteConfig.title}` : siteConfig.title;
const canonical = new URL(Astro.url.pathname, Astro.site ?? "http://localhost:4321");
const ogImage = new URL(withBase(image), Astro.site ?? "http://localhost:4321");
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08090d" />
    <link rel="canonical" href={canonical} />
    <title>{pageTitle}</title>
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="alternate" type="application/rss+xml" title="RSS" href={withBase("/rss.xml")} />
  </head>
  <body>
    <div class="mx-auto flex min-h-screen w-full max-w-7xl flex-col px-5 sm:px-8">
      <header class="sticky top-0 z-40 border-b border-white/10 bg-ink/80 py-4 backdrop-blur-xl">
        <nav class="flex items-center justify-between gap-6" aria-label="Primary navigation">
          <a href={withBase("/")} class="font-mono text-sm font-semibold text-white">peto.lab</a>
          <div class="hidden items-center gap-5 text-sm text-slate-300 md:flex">
            {siteConfig.nav.map((item) => <a class="transition hover:text-white" href={withBase(item.href)}>{item.label}</a>)}
          </div>
          <a class="rounded-md border border-white/15 px-3 py-2 text-sm text-white transition hover:border-signal hover:text-signal" href={withBase("/admin/")}>Admin</a>
        </nav>
      </header>
      <main class="flex-1">
        <slot />
      </main>
      <footer class="border-t border-white/10 py-8 text-sm text-slate-400">
        <div class="flex flex-col justify-between gap-4 md:flex-row">
          <p>Personal engineering notes, kept in Git and built as a static Astro site.</p>
          <div class="flex gap-4">
            <a href={siteConfig.githubUrl}>GitHub</a>
            <a href={withBase("/rss.xml")}>RSS</a>
            <a href={withBase("/about")}>Resume</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
