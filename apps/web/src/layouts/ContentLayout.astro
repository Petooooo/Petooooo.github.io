---
import BaseLayout from "./BaseLayout.astro";
import { formatDate, normalizeTags } from "@/lib/content";

const { entry } = Astro.props;
const { Content } = await entry.render();
const parentHref = `/${entry.collection}`;
const tags = normalizeTags(entry.data.tags as string[]);
---

<BaseLayout title={entry.data.title} description={entry.data.description} image={entry.data.thumbnail} type="article">
  <article class="mx-auto max-w-3xl py-14">
    <a href={parentHref} class="text-sm text-slate-400 hover:text-white">Back to {entry.collection}</a>
    <header class="mt-8">
      <p class="font-mono text-sm uppercase tracking-[0.18em] text-signal">{entry.collection}</p>
      <h1 class="mt-4 text-4xl font-semibold leading-tight text-white md:text-5xl">{entry.data.title}</h1>
      <p class="mt-5 text-lg text-slate-300">{entry.data.description}</p>
      <dl class="mt-6 grid gap-3 border-y border-white/10 py-4 text-sm text-slate-300 sm:grid-cols-2">
        <div>
          <dt class="font-mono text-xs uppercase tracking-[0.18em] text-slate-500">Published</dt>
          <dd class="mt-1"><time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time></dd>
        </div>
        {entry.data.updated && (
          <div>
            <dt class="font-mono text-xs uppercase tracking-[0.18em] text-slate-500">Updated</dt>
            <dd class="mt-1"><time datetime={entry.data.updated.toISOString()}>{formatDate(entry.data.updated)}</time></dd>
          </div>
        )}
        {entry.data.autoGenerated && (
          <div>
            <dt class="font-mono text-xs uppercase tracking-[0.18em] text-slate-500">Generated</dt>
            <dd class="mt-1">{entry.data.reviewed ? "Reviewed" : "Needs review"}</dd>
          </div>
        )}
        {entry.data.generatedAt && (
          <div>
            <dt class="font-mono text-xs uppercase tracking-[0.18em] text-slate-500">Generated At</dt>
            <dd class="mt-1"><time datetime={entry.data.generatedAt.toISOString()}>{formatDate(entry.data.generatedAt)}</time></dd>
          </div>
        )}
        {entry.data.source && (
          <div>
            <dt class="font-mono text-xs uppercase tracking-[0.18em] text-slate-500">Source</dt>
            <dd class="mt-1">
              {entry.data.sourceUrl ? <a class="text-signal hover:text-white" href={entry.data.sourceUrl}>{entry.data.source}</a> : entry.data.source}
            </dd>
          </div>
        )}
      </dl>
      {tags.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {tags.map((tag) => <span class="rounded-md border border-white/10 px-2.5 py-1 text-xs text-slate-300">{tag}</span>)}
        </div>
      )}
    </header>
    <div class="prose-platform mt-10">
      <Content />
    </div>
  </article>
</BaseLayout>
