---
const { entry, href, label } = Astro.props;
const tags = entry.data.tags as string[];
---

<a href={href} class="group block rounded-lg border border-white/10 bg-white/[0.04] p-5 transition hover:-translate-y-0.5 hover:border-signal/50 hover:bg-white/[0.07]">
  <div class="flex items-center justify-between gap-4">
    <span class="font-mono text-xs uppercase tracking-[0.18em] text-slate-400">{label}</span>
    {entry.data.draft && <span class="rounded-md border border-amber/30 px-2 py-1 text-xs text-amber">Draft</span>}
  </div>
  <h3 class="mt-4 text-xl font-semibold text-white">{entry.data.title}</h3>
  <p class="mt-3 line-clamp-3 text-sm leading-6 text-slate-300">{entry.data.description}</p>
  <div class="mt-5 flex flex-wrap gap-2">
    {tags.slice(0, 4).map((tag) => <span class="rounded-md bg-white/[0.06] px-2 py-1 text-xs text-slate-300">{tag}</span>)}
  </div>
</a>
