---
const { entry, href, label } = Astro.props;
const tags = entry.data.tags as string[];
---

<a href={href} class="group block rounded-md border border-white/10 bg-white/[0.03] p-5 transition hover:border-signal/50 hover:bg-white/[0.05]">
  <div class="flex items-center justify-between gap-4 border-b border-white/10 pb-3">
    <span class="font-mono text-xs uppercase tracking-[0.18em] text-slate-500">{label}</span>
    {entry.data.draft && <span class="rounded border border-amber/30 px-2 py-1 text-xs text-amber">Draft</span>}
  </div>
  <h3 class="mt-4 text-lg font-semibold leading-snug text-white">{entry.data.title}</h3>
  <p class="mt-3 line-clamp-3 text-sm leading-6 text-slate-300">{entry.data.description}</p>
  <div class="mt-5 flex flex-wrap gap-2">
    {tags.slice(0, 4).map((tag) => <span class="rounded border border-white/10 px-2 py-1 text-xs text-slate-300">{tag}</span>)}
  </div>
</a>
