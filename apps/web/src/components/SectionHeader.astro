---
const { eyebrow, title, description } = Astro.props;
---

<div class="mb-8 max-w-3xl">
  {eyebrow && <p class="font-mono text-sm uppercase tracking-[0.18em] text-signal">{eyebrow}</p>}
  <h2 class="mt-3 text-3xl font-semibold leading-tight text-white md:text-4xl">{title}</h2>
  {description && <p class="mt-4 text-base leading-7 text-slate-300">{description}</p>}
</div>
