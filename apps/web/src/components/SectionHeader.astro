---
const { eyebrow, title, description } = Astro.props;
---

<div class="mb-7 max-w-3xl border-l border-white/15 pl-4">
  {eyebrow && <p class="font-mono text-xs uppercase tracking-[0.18em] text-slate-500">{eyebrow}</p>}
  <h2 class="mt-2 text-2xl font-semibold leading-tight text-white md:text-3xl">{title}</h2>
  {description && <p class="mt-4 text-base leading-7 text-slate-300">{description}</p>}
</div>
