---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContentCard from "@/components/ContentCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { byDateDesc, getCollectionUrl, isPublishedEntry } from "@/lib/content";
const entries = (await getCollection("auto-archive")).filter(isPublishedEntry).sort(byDateDesc);
---
<BaseLayout title="Archive" description="Reviewed generated notes and draft workflow records.">
  <section class="py-14">
    <SectionHeader eyebrow="Archive" title="Reviewed Draft Archive" description="A separate lane for generated or automation-assisted notes that have been checked, cleaned, and intentionally published." />
    <div class="grid gap-5 md:grid-cols-2">{entries.map((entry) => <ContentCard entry={entry} href={getCollectionUrl(entry)} label={entry.data.autoGenerated ? "auto generated" : "archive"} />)}</div>
  </section>
</BaseLayout>
