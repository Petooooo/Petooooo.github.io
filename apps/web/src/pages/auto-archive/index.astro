---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContentCard from "@/components/ContentCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { byDateDesc, getCollectionUrl, isPublishedEntry } from "@/lib/content";
const entries = (await getCollection("auto-archive")).filter(isPublishedEntry).sort(byDateDesc);
---
<BaseLayout title="Auto Archive" description="Reviewed automation-generated archive posts.">
  <section class="py-14">
    <SectionHeader eyebrow="Automation lane" title="Auto Archive" description="A reserved publication lane for generated drafts after human review. Drafts stay in Git until intentionally published." />
    <div class="grid gap-5 md:grid-cols-2">{entries.map((entry) => <ContentCard entry={entry} href={getCollectionUrl(entry)} label={entry.data.autoGenerated ? "auto generated" : "archive"} />)}</div>
  </section>
</BaseLayout>
