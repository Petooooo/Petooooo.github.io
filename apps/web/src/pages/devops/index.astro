---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContentCard from "@/components/ContentCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { byDateDesc, getCollectionUrl, isPublishedEntry } from "@/lib/content";
const entries = (await getCollection("devops")).filter(isPublishedEntry).sort(byDateDesc);
---
<BaseLayout title="DevOps Logs" description="Infrastructure operation notes.">
  <section class="py-14">
    <SectionHeader eyebrow="Operations" title="DevOps Logs" description="Deployment notes and runbooks for the parts of the platform that need to be repeatable." />
    <div class="grid gap-5 md:grid-cols-2">{entries.map((entry) => <ContentCard entry={entry} href={getCollectionUrl(entry)} label="devops" />)}</div>
  </section>
</BaseLayout>
