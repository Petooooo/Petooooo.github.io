---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContentCard from "@/components/ContentCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { byDateDesc, getCollectionUrl, isPublishedEntry } from "@/lib/content";
const entries = (await getCollection("research")).filter(isPublishedEntry).sort(byDateDesc);
---
<BaseLayout title="Research" description="Research and computational study notes.">
  <section class="py-14">
    <SectionHeader eyebrow="Research" title="Research Notes" description="Structured notes for computational questions, assumptions, small experiments, and reproducibility details." />
    <div class="grid gap-5 md:grid-cols-2">{entries.map((entry) => <ContentCard entry={entry} href={getCollectionUrl(entry)} label="research" />)}</div>
  </section>
</BaseLayout>
