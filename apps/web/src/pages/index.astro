---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContentCard from "@/components/ContentCard.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { siteConfig } from "@/site.config";
import { byDateDesc, getCollectionUrl, isPublishedEntry } from "@/lib/content";
import { withBase } from "@/lib/urls";

const projects = (await getCollection("projects")).filter(isPublishedEntry);
const posts = [
  ...(await getCollection("notes")),
  ...(await getCollection("devops")),
  ...(await getCollection("research")),
  ...(await getCollection("auto-archive"))
]
  .filter(isPublishedEntry)
  .sort(byDateDesc);
const featuredProjects = projects.filter((p) => p.data.featured).slice(0, 3);
const recentPosts = posts.slice(0, 4);
---

<BaseLayout>
  <section class="grid gap-10 border-b border-white/10 py-12 md:grid-cols-[1fr_0.8fr] md:py-16">
    <div>
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-slate-500">Personal engineering / research lab</p>
      <h1 class="mt-5 max-w-3xl text-4xl font-semibold leading-tight text-white md:text-6xl">
        Notes from a small systems lab.
      </h1>
      <p class="mt-6 max-w-2xl text-base leading-8 text-slate-300 md:text-lg">
        A long-term notebook for static site architecture, self-hosting, Raspberry Pi deployment work, computational research notes, and the small decisions that make systems easier to operate later.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="rounded border border-white/20 px-4 py-2.5 text-sm font-semibold text-white hover:border-signal hover:text-signal" href={withBase("/notes")}>Read Notes</a>
        <a class="rounded border border-white/20 px-4 py-2.5 text-sm font-semibold text-white hover:border-signal hover:text-signal" href={withBase("/research")}>Research</a>
        <a class="rounded border border-white/20 px-4 py-2.5 text-sm font-semibold text-white hover:border-signal hover:text-signal" href={siteConfig.githubUrl}>GitHub</a>
      </div>
    </div>
    <aside class="border-l border-white/10 pl-5">
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-slate-500">Repository workflow</p>
      <dl class="mt-6 grid gap-5">
        {[
          ["Input", "Codex sessions, local notes, RP4 experiments"],
          ["Format", "Markdown and MDX content collections"],
          ["Review", "Git diff, Decap CMS, manual edits"],
          ["Deploy", "GitHub Pages now; RP4 path documented"]
        ].map(([label, value]) => (
          <div>
            <dt class="font-mono text-xs uppercase tracking-[0.16em] text-slate-500">{label}</dt>
            <dd class="mt-1 text-sm leading-6 text-slate-200">{value}</dd>
          </div>
        ))}
      </dl>
    </aside>
  </section>

  <section class="py-12 md:py-14">
    <SectionHeader eyebrow="Lab Index" title="Current Threads" description="The archive is organized around work that accumulates: systems projects, operational notes, research questions, and generated drafts that still require review." />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {[
        ["Projects", "Implementation records and architecture decisions.", "/projects"],
        ["Research", "Computational questions, assumptions, and reproducibility notes.", "/research"],
        ["DevOps", "Deployment routines, infrastructure choices, and troubleshooting.", "/devops"],
        ["Archive", "Reviewed generated notes and draft workflow experiments.", "/auto-archive"]
      ].map(([title, description, href]) => (
        <a class="rounded-md border border-white/10 bg-white/[0.03] p-4 hover:border-signal/50" href={withBase(href)}>
          <h3 class="text-base font-semibold text-white">{title}</h3>
          <p class="mt-2 text-sm leading-6 text-slate-300">{description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="py-12 md:py-14">
    <SectionHeader eyebrow="Build log" title="Projects" description="Systems and platform work documented with constraints, implementation notes, and unfinished edges." />
    <div class="grid gap-5 md:grid-cols-3">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="py-12 md:py-14">
    <SectionHeader eyebrow="Recent entries" title="Notebook" description="Technical notes, runbooks, and research entries written for reuse rather than social posting." />
    <div class="grid gap-5 md:grid-cols-2">
      {recentPosts.map((entry) => <ContentCard entry={entry} href={getCollectionUrl(entry)} label={entry.collection} />)}
    </div>
  </section>

  <section class="grid gap-8 border-t border-white/10 py-12 md:grid-cols-[0.8fr_1.2fr] md:py-14">
    <SectionHeader eyebrow="Operating Bias" title="Static, Git-based, recoverable." description="The site favors plain files and repeatable commands over hidden state. Automation can prepare drafts, but publishing stays manual." />
    <div class="grid gap-3 sm:grid-cols-2">
      {[
        "Astro static output",
        "Typed MDX collections",
        "GitHub Pages deployment",
        "RP4 Docker/Caddy path",
        "Decap CMS as a Git editor",
        "Draft-first automation",
        "No database requirement",
        "No login surface"
      ].map((item) => (
        <div class="border-b border-white/10 py-3 text-sm text-slate-200">{item}</div>
      ))}
    </div>
  </section>
</BaseLayout>
