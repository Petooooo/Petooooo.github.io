---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Not Found" description="The requested page was not found.">
  <section class="mx-auto max-w-2xl py-24 text-center">
    <p class="font-mono text-sm uppercase tracking-[0.18em] text-signal">404</p>
    <h1 class="mt-4 text-4xl font-semibold text-white">Page not found</h1>
    <p class="mt-4 text-slate-300">The content may still be a draft, renamed, or waiting for review.</p>
    <a class="mt-8 inline-flex rounded-md bg-white px-4 py-2.5 text-sm font-semibold text-ink" href="/">Return Home</a>
  </section>
</BaseLayout>
